@{
    ViewData["Title"] = "Projects";
    ViewData["ActiveTab"] = "Projects";
}

<h1>My Projects</h1>
<br>

<div class="module-container">

    <!-- Preview Box (Box 1) -->
    <div class="preview-box">
        <img src="~/images/placeholder.png" alt="Preview" />
        <h3>Project Title</h3>
        <p>Project description goes here.</p>
    </div>

    <!-- Sticker Container -->
    <div class="sticker-container">
        <div class="sticker" data-type="personal">
            <span>🎨</span>
            <h4>Personal Design</h4>
        </div>

        <div class="sticker" data-type="pubmats">
            <span>🖼️</span>
            <h4>PubMats</h4>
        </div>

        <div class="sticker" data-type="creative">
            <span>💡</span>
            <h4>Creative Works</h4>
        </div>
    </div>

</div>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', () => {
    const previewBox = document.querySelector('.preview-box');
    const previewImg = previewBox.querySelector('img');
    const previewTitle = previewBox.querySelector('h3');
    const previewDesc = previewBox.querySelector('p');

    const stickerContainer = document.querySelector('.sticker-container');
    const stickers = document.querySelectorAll('.sticker');

    stickers.forEach(sticker => {
        sticker.addEventListener('click', () => {

            // Remove previous selection
            stickers.forEach(s => s.classList.remove('selected'));
            sticker.classList.add('selected');

            // Show preview
            previewBox.classList.add('expanded');

            // Remove previous overlay clone
            const prevClone = previewBox.querySelector('.selected-clone');
            if (prevClone) prevClone.remove();

            // Clone sticker → overlay in upper-right corner
            const clone = sticker.cloneNode(true);
            clone.classList.remove('selected');
            clone.classList.add('selected-clone');
            previewBox.appendChild(clone);

            // Fade others
            stickerContainer.classList.add('sticker-active');

            // Update preview content
            const type = sticker.dataset.type;

            if (type === 'personal') {
                previewTitle.textContent = 'Personal Design';
                previewImg.src = '/images/personal1.jpg';
                previewDesc.textContent = 'Collection of personal artwork and sketches.';
            }

            else if (type === 'pubmats') {
                previewTitle.textContent = 'Publication Materials';
                previewImg.src = '/images/pubmat1.jpg';
                previewDesc.textContent = 'Posters, flyers, and creative publication designs.';
            }

            else if (type === 'creative') {
                previewTitle.textContent = 'Other Creative Works';
                previewImg.src = '/images/creative1.jpg';
                previewDesc.textContent = 'Thought projects, illustrations, and experiments.';
            }
        });
    });
});
</script>
}

<style>
/* ===== Base & Reset ===== */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: Arial, sans-serif;
    background: #2b2b2b;
    color: #fff;
    min-height: 100vh;
    padding: 20px;
}

/* ===== Folder-Style Navbar ===== */
.navbar {
    display: flex;
    gap: 10px;
}

.nav-item {
    min-width: 140px;
    padding: 16px 20px;
    text-align: center;
    font-weight: bold;
    background: #FFD966;
    color: #333;
    border-top-left-radius: 12px;
    border-top-right-radius: 12px;
    cursor: pointer;
    transition: 0.3s;
    box-shadow: inset 0 4px 0 #e6c200;
}

.nav-item a {
    text-decoration: none;
    color: inherit;
}

.nav-item.active,
.nav-item:hover {
    background: #FFEB99;
    color: #000;
}

/* ===== Module Container ===== */
.module-container {
    background: #FFEB99;
    padding: 20px;
    border-radius: 0 0 8px 8px;
}

/* ===== Preview Box ===== */
.preview-box {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 20px;
    position: relative; /* anchor for overlay sticker */
    overflow: visible; /* allow sticker overlay */
}

.preview-box.expanded {
    display: flex;
}

.preview-box img {
    max-width: 80%;
    max-height: 60%;
}

/* ===== Sticker Container ===== */
.sticker-container {
    display: grid;
    grid-template-columns: repeat(3, 120px);
    gap: 20px;
    position: relative;
}

/* ===== Sticker ===== */
.sticker {
    width: 120px;
    height: 120px;
    background: transparent;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: 0.3s ease;
}

.sticker span {
    font-size: 2.5rem;
}

.sticker h4 {
    font-size: 0.85rem;
    color: #fff;
    margin-top: 6px;
}

/* ===== Active Sticker Overlay ===== */
.sticker.selected {
    position: absolute;
    top: 10px; /* upper right of preview box */
    right: 10px;
    transform: scale(1.1);
    z-index: 100;
    pointer-events: none;
}

/* Overlay clone for smoother effect */
.selected-clone {
    position: absolute;
    top: 10px;
    right: 10px;
    width: 80px;
    height: 80px;
    z-index: 200;
    pointer-events: none;
    transform: rotate(10deg) scale(1.1);
}

.selected-clone span {
    font-size: 1.8rem;
}

.selected-clone h4 {
    font-size: 0.7rem;
}

/* Keep others slightly faded */
.sticker-container.sticker-active .sticker:not(.selected) {
    opacity: 0.5;
}
</style>