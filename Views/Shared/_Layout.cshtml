<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PortfolioDemo</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <!-- Folder-Style Navbar -->
    <nav class="navbar">
        <div class="nav-item @(ViewData["ActiveTab"]?.ToString() == "Home" ? "active" : "")">
            <a asp-area="" asp-controller="Home" asp-action="Index">Home</a>
        </div>
        <div class="nav-item @(ViewData["ActiveTab"]?.ToString() == "Projects" ? "active" : "")">
            <a asp-area="" asp-controller="Home" asp-action="Projects">Projects</a>
        </div>
        <div class="nav-item @(ViewData["ActiveTab"]?.ToString() == "About" ? "active" : "")">
            <a asp-area="" asp-controller="Home" asp-action="About">About Me</a>
        </div>
        <div class="nav-item @(ViewData["ActiveTab"]?.ToString() == "Contact" ? "active" : "")">
            <a asp-area="" asp-controller="Home" asp-action="Contact">Contact</a>
        </div>
    </nav>

    <div class="module-container">
        @RenderBody()
    </div>

    <footer class="footer">
        &copy; @DateTime.Now.Year - PortfolioDemo
    </footer>

    @RenderSection("Scripts", required: false)
</body>
</html>