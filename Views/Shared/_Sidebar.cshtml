@* Sidebar for Folder-style Layout *@
<div class="header-sidebar">
    <img src="~/images/logo.png" alt="Logo" class="sidebar-image" />
    <nav class="sidebar-nav">
        <ul>
            <li class="sidebar-item @(ViewData["ActiveSidebar"]?.ToString() == "Home" ? "active" : "")">
                <a asp-area="" asp-controller="Home" asp-action="Index">Home</a>
            </li>
            <li class="sidebar-item @(ViewData["ActiveSidebar"]?.ToString() == "Portfolio" ? "active" : "")">
                <a asp-area="" asp-controller="Home" asp-action="Portfolio">Portfolio</a>
            </li>
            <li class="sidebar-item @(ViewData["ActiveSidebar"]?.ToString() == "About" ? "active" : "")">
                <a asp-area="" asp-controller="Home" asp-action="About">About Me</a>
            </li>
            <li class="sidebar-item @(ViewData["ActiveSidebar"]?.ToString() == "Contact" ? "active" : "")">
                <a asp-area="" asp-controller="Home" asp-action="Contact">Contact</a>
            </li>
        </ul>
    </nav>
</div>